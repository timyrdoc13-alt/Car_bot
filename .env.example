BOT_TOKEN=123456:ABC...
CHANNEL_ID=-1001234567890
ADMIN_IDS=111111111,222222222,333333333

LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
# LLM_MAX_RETRIES=4
# LLM_RETRY_BASE_SECONDS=1.0
# LLM_MAX_TOKENS=800
# CAPTION_CACHE_TTL_SECONDS=0

# Локально: ./data/bot.db | в Docker Compose для сервиса bot задаётся /app/data/bot.db из compose
DATABASE_PATH=./data/bot.db
DEDUP_TTL_DAYS=30
LOG_LEVEL=INFO

PLAYWRIGHT_HEADLESS=true

FX_ENABLED=true
NBRB_FX_URL=https://api.nbrb.by/exrates/rates?periodicity=0
FX_CACHE_TTL_SECONDS=3600

# stub | lalafo | mashina — автопостинг идёт сюда; монитор :8765 всегда только Mashina
LISTING_SOURCE=stub
LALAFO_SEARCH_URL=https://lalafo.kg/kyrgyzstan/avtomobili-s-probegom
LALAFO_REQUEST_DELAY_SECONDS=2
MASHINA_SEARCH_URL=https://m.mashina.kg/search/all/?region=all
MASHINA_REQUEST_DELAY_SECONDS=2
AUTO_DETAIL_CONCURRENCY=3
AUTO_LLM_CONCURRENCY=2

AUTO_SCHEDULE_CRON=
AUTO_SCHEDULE_FILTERS_JSON={"limit": 5}

# Локальный мониторинг Mashina: пусто = POST /api/mashina/probe только с localhost; иначе заголовок X-Mashina-Monitor-Token
MASHINA_MONITOR_TOKEN=

MANAGER_USERNAME=

# Публикация в канал: до N фото (после фильтра URL), пауза между постами (Flood control)
CHANNEL_GALLERY_MIN_PHOTOS=4
CHANNEL_GALLERY_MAX_PHOTOS=6
CHANNEL_POST_COOLDOWN_SECONDS=4
# IMAGE_DOWNLOAD_CONCURRENCY=4

# Redis (FSM + опциональная очередь); пусто — MemoryStorage, пайплайн в процессе бота
# REDIS_URL=redis://redis:6379/0
# PIPELINE_QUEUE_KEY=car-bot:pipeline:jobs
# FSM_STATE_TTL_SECONDS=604800
